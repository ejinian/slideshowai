# Copy this file to `.env.local` and fill in the values.
# Anything NOT prefixed NEXT_PUBLIC_ is server-only — NEVER expose secret keys
# to the browser.

# --- Supabase ---------------------------------------------------------------
# From Supabase dashboard → project → Connect → Framework (Next.js).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# Admin key (sb_secret_…). Service-role writes (billing entitlements), the TikTok
# image proxy, and E2E test-user provisioning. Must be a VALID full key.
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here

# --- OpenAI (server-only) ---------------------------------------------------
# gpt-4o — captions + vision image matching.
OPENAI_API_KEY=sk-your-openai-key-here

# --- Pexels (server-only) ---------------------------------------------------
# Stock library ingest AND live runtime image search. Without it, stock
# backgrounds fall back to the frozen library instead of live Pexels + AI-gen.
PEXELS_API_KEY=your-pexels-api-key

# --- TikTok Content Posting API (server-only) -------------------------------
# From developers.tiktok.com → your app → app details.
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
# Deployed app URL (no trailing slash). OAuth redirect URIs + image proxy URLs.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Stripe (billing, server-only) ------------------------------------------
STRIPE_SECRET_KEY=sk_test_or_live_your_key
# Endpoint signing secret (prod's differs from the local `stripe listen` one).
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# ONE JSON blob mapping plan/credit ids → Stripe price ids, e.g.
# {"growth":"price_...","scale":"price_...","unlimited":"price_...","credits_small":"price_..."}
STRIPE_PRICES={"growth":"price_...","scale":"price_...","unlimited":"price_..."}

# --- Crons + trends (server-only) -------------------------------------------
# Shared secret guarding /api/cron/* (scheduled posting + trends refresh). Any
# random string — must match the value set in the external cron service.
CRON_SECRET=your-random-cron-secret
# Apify token for live TikTok trends. Absent → the Grow suite uses mock data.
APIFY_TOKEN=your-apify-token
